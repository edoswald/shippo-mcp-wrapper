# Shippo credentials
# Option 1: Direct API key (preferred for admin use)
SHIPPO_API_KEY=shippo_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: OAuth client credentials (if using Shippo Platform App)
# SHIPPO_CLIENT_ID=your_shippo_client_id
# SHIPPO_CLIENT_SECRET=your_shippo_client_secret

# SSE Bearer tokens for Retell and other MCP clients
# Each client gets its own token. Add SSE_TOKEN_<NAME> for each client.
SSE_TOKEN_RETELL=your_retell_token_here
SSE_TOKEN_HAL=your_hal_token_here

# Server port (Railway sets this automatically)
PORT=3000

# Optional: limit concurrent SSE connections
# MAX_CONNECTIONS=20
